// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  TUTOR
  PARENT
  ADMIN
  MASTER_ADMIN
}

enum TeachingMode {
  IN_PERSON
  ONLINE
  BOTH
}

enum ConversationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  phoneNumber   String?   // Added
 
  role          Role      @default(TUTOR) 
  createdAt     DateTime  @default(now()) 
  updatedAt     DateTime  @updatedAt  

  tutor               Tutor?
  accounts            Account[]
  sessions            Session[]
  parentConversations Conversation[] @relation("ParentConversations")
  sentMessages        Message[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Tutor {
  id                String      @id @default(cuid())
  userId            String      @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Mandatory fields
  name              String
  subject           String
  hourlyRate        Float       // Changed from price
  teachingMode      TeachingMode
  governorate       String      // Added
  district          String      // Added
  city              String      // Added
  
  // Optional fields
  phoneNumber       String?     // Added
  bio               String?
  profilePictureUrl String?

  // Verification fields
  isVerified        Boolean     @default(false)
  verifiedDegree    String?

  conversations     Conversation[] @relation("TutorConversations")
  educations        Education[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("tutors")
}

model Education {
  id          String   @id @default(cuid())
  tutorId     String
  tutor       Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  degree      String
  major       String
  university  String
  documentUrl String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("educations")
}

model Conversation {
  id        String             @id @default(cuid())
  parentId  String
  parent    User               @relation("ParentConversations", fields: [parentId], references: [id], onDelete: Cascade)
  tutorId   String
  tutor     Tutor              @relation("TutorConversations", fields: [tutorId], references: [id], onDelete: Cascade)
  status    ConversationStatus @default(PENDING)
  messages  Message[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([parentId, tutorId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@map("messages")
}
