// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// This block tells Prisma how to generate the client library
generator client {
  provider = "prisma-client-js"  // Use the JavaScript/TypeScript client
}
// The generator creates code you'll import to interact with the database

// This block defines where your database is and what type it is
datasource db {
  provider = "postgresql"  // We're using PostgreSQL (Neon uses Postgres)
  url      = env("DATABASE_URL")  // Connection string from .env file
}
// The datasource tells Prisma how to connect to your Neon database
// directUrl is used for migrations, url is used for queries (can use connection pooling)

// User model for authentication
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          String    @default("TUTOR") // TUTOR, PARENT, ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  tutor         Tutor?    // One-to-one relationship with Tutor
}

// NextAuth Account model for OAuth providers
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth Verification Token model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// This block defines the structure of the "Tutor" table in your database
model Tutor {
  id                Int     @id @default(autoincrement())  // Primary key, auto-increments (1, 2, 3...)
  userId            String  @unique  // Foreign key to User model
  name              String  // Text field for tutor's name
  subject           String  // Text field for subject they teach
  bio               String?
  profilePictureUrl String? // URL to profile picture stored in Vercel Blob (optional)
  price             Float?  // Price per hour in currency units (optional)
  location          String? // Location as "City, Country" format (optional)

  // Relations
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
// The model creates a table with columns for tutor info including profile picture, price, and location
// Email is now stored in the User model, not here
